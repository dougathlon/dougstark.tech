---
import Card from "./Card.astro";
import StatusBadge from "./StatusBadge.astro";
import { slugFor } from "../lib/content";
import { patternFor } from "../lib/visual";

const { entry, patternSeed } = Astro.props;
---

<Card
  pattern={patternFor(patternSeed ?? slugFor(entry))}
  class={`constellation-card ${entry.data.featured ? "is-featured" : ""}`}
>
  <h2>{entry.data.title}</h2>
  <StatusBadge status={entry.data.status} visibility={entry.data.visibility} />
  {entry.data.summary && <p>{entry.data.summary}</p>}
</Card>
